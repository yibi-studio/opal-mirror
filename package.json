{
  "name": "opal-mirror",
  "version": "0.4.0",
  "description": "Sync web LLM chat history to local JSON and mirror it into terminal Codex /resume and Codex App sessions",
  "type": "module",
  "bin": {
    "opal-mirror": "./bin/opal-mirror.mjs"
  },
  "scripts": {
    "doctor": "node doctor.mjs",
    "sync": "node sync.mjs",
    "sync:claude": "node sync.mjs claude",
    "sync:chatgpt": "node sync.mjs chatgpt",
    "sync:gemini": "node sync.mjs gemini",
    "sync:deepseek": "node sync.mjs deepseek",
    "sync:doubao": "node sync.mjs doubao",
    "sync:qwen": "node sync.mjs qwen",
    "export:codex": "node export_codex.mjs",
    "repair:codex-app": "node repair_codex_app_frontend.mjs",
    "index": "node build_index.mjs",
    "test": "node test_codex_export.mjs && node test_doctor.mjs && node test_skill_product.mjs",
    "test:e2e": "node test_e2e.mjs",
    "test:skill": "node test_skill_product.mjs",
    "test:all": "node test_e2e.mjs && node test_codex_export.mjs && node test_doctor.mjs && node test_skill_product.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/1va7/opal-mirror.git"
  },
  "license": "MIT"
}
