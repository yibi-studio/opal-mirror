{
  "name": "chat-history-sync",
  "version": "0.3.0",
  "description": "Sync Claude / ChatGPT / Gemini / DeepSeek / Doubao / Qwen chat history to local JSON via Chrome DevTools Protocol",
  "type": "module",
  "scripts": {
    "doctor": "node doctor.mjs",
    "sync": "node sync.mjs",
    "sync:claude": "node sync.mjs claude",
    "sync:chatgpt": "node sync.mjs chatgpt",
    "sync:gemini": "node sync.mjs gemini",
    "sync:deepseek": "node sync.mjs deepseek",
    "sync:doubao": "node sync.mjs doubao",
    "sync:qwen": "node sync.mjs qwen",
    "export:pixel": "node export_pixel_distill.mjs",
    "export:codex": "node export_codex.mjs",
    "index": "node build_index.mjs",
    "test": "node test_codex_export.mjs",
    "test:e2e": "node test_e2e.mjs",
    "test:pixel": "node test_pixel_export.mjs",
    "test:all": "node test_e2e.mjs && node test_pixel_export.mjs && node test_codex_export.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/1va7/chat-history-sync.git"
  },
